---
// src/components/AcademicLevels.astro

const levels = [
    {
        id: "01",
        title: "Primaria",
        subtitle: "Bases Sólidas",
        desc: "Formación integral en ciencias y humanidades.",
        details: ["Pensamiento Lógico", "Robótica Básica", "Deportes", "Lectura Comprensiva"],
        iconPath: "M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"
    },
    {
        id: "02",
        title: "Secundaria",
        subtitle: "Pre-Universitario",
        desc: "Preparación intensiva para la vida universitaria.",
        details: ["Bachillerato Bilingüe", "Laboratorios STEAM", "Liderazgo", "Orientación"],
        iconPath: "M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23-.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5"
    }
];
---

<section class="py-16 md:py-24 bg-white border-t border-gray-200">
    <div class="container mx-auto px-6">

        <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 md:mb-16 border-b-2 border-gray-900 pb-6 md:pb-8">
            <div class="w-full md:w-auto mb-4 md:mb-0">
                <span class="text-[#000089] font-bold uppercase tracking-widest text-[10px] md:text-xs mb-2 block">
                    Oferta Académica
                </span>
                <h2 class="text-3xl md:text-5xl font-black text-gray-900 leading-[0.9] md:leading-none tracking-tighter uppercase">
                    Niveles de <br class="hidden md:block">Formación
                </h2>
            </div>

            <div class="w-full md:w-auto flex justify-start md:justify-end">
                <p class="text-left md:text-right text-gray-500 max-w-xs text-sm font-medium border-l-2 border-gray-200 pl-4 md:pl-0 md:border-l-0 md:border-r-2 md:pr-4">
                    Un plan curricular integrado desde los primeros pasos hasta la graduación.
                </p>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 border-t border-l border-gray-200">
            {levels.map((level) => (
                    <div tabindex="0" class="group relative bg-white border-r border-b border-gray-200 p-8 md:p-10 hover:bg-[#000089] focus:bg-[#000089] transition-all duration-500 ease-out flex flex-col justify-between h-full md:min-h-[500px] overflow-hidden cursor-pointer focus:outline-none">

                    <span class="absolute -top-4 -right-4 md:-top-6 md:-right-6 text-7xl md:text-9xl font-black text-gray-50 group-hover:text-white/10 group-focus:text-white/10 transition-colors select-none leading-none z-0">
                        {level.id}
                    </span>

                        <div class="relative z-10 flex-grow">

                            <div class="flex items-center justify-between mb-6 md:mb-8">
                            <span class="text-[10px] md:text-xs font-bold uppercase tracking-[0.2em] text-gray-400 group-hover:text-blue-300 group-focus:text-blue-300 transition-colors">
                                Nivel {level.id}
                            </span>
                                <div class="w-8 h-8 md:w-10 md:h-10 text-[#000089] group-hover:text-white group-focus:text-white transition-colors">
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-full h-full">
                                        <path stroke-linecap="square" stroke-linejoin="miter" d={level.iconPath} />
                                    </svg>
                                </div>
                            </div>

                            <h3 class="text-2xl md:text-3xl font-black text-gray-900 mb-1 md:mb-2 group-hover:text-white group-focus:text-white transition-colors uppercase tracking-tight">
                                {level.title}
                            </h3>
                            <p class="text-[10px] md:text-xs font-bold text-[#000089] uppercase tracking-widest mb-4 md:mb-6 group-hover:text-blue-200 group-focus:text-blue-200 transition-colors">
                                {level.subtitle}
                            </p>

                            <p class="text-xs md:text-sm text-gray-500 leading-relaxed mb-6 md:mb-8 group-hover:text-blue-100/90 group-focus:text-blue-100/90 transition-colors font-medium">
                                {level.desc}
                            </p>

                            <ul class="space-y-3 border-t border-gray-100 group-hover:border-white/20 group-focus:border-white/20 pt-5 md:pt-6 transition-colors">
                                {level.details.map((detail) => (
                                        <li class="flex items-start gap-3 text-xs md:text-sm font-bold text-gray-600 group-hover:text-white group-focus:text-white transition-colors">
                                            <span class="w-1.5 h-1.5 bg-[#000089] group-hover:bg-blue-400 group-focus:bg-blue-400 transition-colors shrink-0 mt-1.5"></span>
                                            <span class="leading-tight">{detail}</span>
                                        </li>
                                ))}
                            </ul>
                        </div>

                        <div class="mt-8 relative z-10 shrink-0">
                            <a href={`/academico#${level.title.toLowerCase()}`} class="inline-flex items-center gap-2 text-[10px] md:text-xs font-black uppercase tracking-widest text-[#000089] group-hover:text-white group-focus:text-white transition-colors group/btn">
                                <span class="border-b-2 border-[#000089] group-hover:border-white group-focus:border-white pb-0.5 transition-colors">Ver Malla</span>
                                <span class="group-hover:translate-x-1 group-focus:translate-x-1 transition-transform duration-300">→</span>
                            </a>
                        </div>

                    </div>
            ))}
        </div>
    </div>
</section>