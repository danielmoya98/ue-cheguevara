---
// src/components/admisiones.astro
const steps = [
    { title: "Pre-inscripción", desc: "Llenado del formulario digital y reserva de cupo." },
    { title: "Entrevista Familiar", desc: "Reunión con psicología y dirección académica." },
    { title: "Documentación", desc: "Entrega de requisitos físicos en secretaría." },
    { title: "Matriculación", desc: "Pago de la primera cuota y firma de contrato." }
];

const requirements = [
    "Certificado de Nacimiento Original",
    "Cédula de Identidad (Estudiante y Padres)",
    "Libreta de Calificaciones (Gestión Anterior)",
    "Certificado de Vacunas (Nivel Inicial)",
    "Certificado de No Adeudo (Si viene de otro colegio)"
];
---

<section id="admisiones" class="py-16 md:py-24 bg-white border-t border-gray-100 font-sans">
    <div class="container mx-auto px-6">

        <div class="grid lg:grid-cols-12 gap-12 lg:gap-24">

            <div class="lg:col-span-7">
                <span class="text-[#000089] font-bold uppercase tracking-widest text-[10px] md:text-xs mb-4 md:mb-6 flex items-center gap-2">
                    <span class="w-2 h-2 bg-[#000089]"></span> Únete a Nosotros
                </span>

                <h2 class="text-3xl md:text-5xl lg:text-6xl font-black text-gray-900 mb-10 md:mb-16 leading-[0.9] tracking-tighter uppercase">
                    Proceso de <br>
                    <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#000089] to-blue-600">Admisión 2026</span>
                </h2>

                <div class="flex flex-col">
                    {steps.map((step, index) => (
                            <div tabindex="0" class="group py-6 md:py-8 border-t border-gray-200 hover:border-[#000089] focus:border-[#000089] focus:outline-none transition-colors duration-300 flex flex-col sm:flex-row sm:items-baseline gap-2 sm:gap-8 md:gap-12 cursor-pointer md:cursor-default">

                            <span class="text-3xl md:text-4xl font-black text-gray-200 group-hover:text-[#000089] group-focus:text-[#000089] transition-colors duration-300 tabular-nums font-mono leading-none">
                                0{index + 1}
                            </span>

                                <div class="mt-1 sm:mt-0">
                                    <h3 class="text-xl md:text-2xl font-bold text-gray-900 mb-1 md:mb-2 group-hover:translate-x-2 group-focus:translate-x-2 transition-transform duration-300 ease-out leading-tight uppercase tracking-tight">
                                        {step.title}
                                    </h3>
                                    <p class="text-gray-500 text-sm md:text-base leading-relaxed max-w-md group-hover:text-gray-700 group-focus:text-gray-700 transition-colors">
                                        {step.desc}
                                    </p>
                                </div>
                            </div>
                    ))}
                    <div class="border-t border-gray-200"></div>
                </div>
            </div>

            <div class="lg:col-span-5 flex flex-col h-full mt-4 lg:mt-0">

                <div class="bg-gray-50 p-6 md:p-10 lg:p-12 h-full flex flex-col justify-between border-l-4 border-[#000089] relative overflow-hidden shadow-sm">

                    <div class="absolute -top-10 -right-10 w-40 h-40 bg-[#000089]/5 rounded-full blur-3xl pointer-events-none"></div>

                    <div>
                        <h3 class="text-xl md:text-2xl font-bold text-gray-900 mb-6 md:mb-8 flex items-center gap-3 md:gap-4 uppercase tracking-tight">
                            <div class="w-8 h-8 md:w-10 md:h-10 bg-white border border-gray-200 flex items-center justify-center text-[#000089] shrink-0">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 md:w-5 md:h-5">
                                    <path stroke-linecap="square" stroke-linejoin="miter" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z" />
                                </svg>
                            </div>
                            Requisitos
                        </h3>

                        <ul class="space-y-3 md:space-y-4">
                            {requirements.map((req) => (
                                    <li tabindex="0" class="flex items-start gap-3 md:gap-4 group cursor-pointer md:cursor-default focus:outline-none">
                                        <div class="w-4 h-4 md:w-5 md:h-5 mt-0.5 md:mt-1 border border-gray-300 bg-white flex items-center justify-center group-hover:border-[#000089] group-focus:border-[#000089] transition-colors duration-300 shrink-0">
                                            <svg class="w-2.5 h-2.5 md:w-3 md:h-3 text-[#000089] opacity-0 group-hover:opacity-100 group-focus:opacity-100 transition-opacity duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                                            </svg>
                                        </div>
                                        <span class="text-gray-600 text-xs md:text-sm font-medium group-hover:text-gray-900 group-focus:text-gray-900 transition-colors leading-snug md:leading-relaxed">
                                        {req}
                                    </span>
                                    </li>
                            ))}
                        </ul>
                    </div>

                    <div class="mt-8 md:mt-12 pt-6 md:pt-8 border-t border-gray-200">
                        <p class="text-[10px] md:text-xs font-bold uppercase tracking-widest text-gray-400 mb-3 md:mb-4">Descargas Útiles</p>
                        <div class="grid grid-cols-1 gap-2 md:gap-3">
                            <a href="https://wa.me/591XXXXXXXX" class="w-full bg-[#000089] text-white py-3 md:py-4 px-4 md:px-6 text-center font-bold uppercase tracking-widest text-[10px] md:text-xs hover:bg-blue-900 focus:bg-blue-900 transition-all flex items-center justify-center gap-2 group shadow-sm hover:shadow-md outline-none">
                                <span>Contactar Asesor</span>
                                <span class="group-hover:translate-x-1 transition-transform">→</span>
                            </a>
                            <a href="#" class="w-full border border-gray-300 text-gray-600 py-3 md:py-4 px-4 md:px-6 text-center font-bold uppercase tracking-widest text-[10px] md:text-xs hover:border-[#000089] hover:text-[#000089] focus:border-[#000089] focus:text-[#000089] bg-white transition-all shadow-sm hover:shadow-md outline-none">
                                Descargar Guía PDF
                            </a>
                        </div>
                    </div>

                </div>
            </div>

        </div>
    </div>
</section>